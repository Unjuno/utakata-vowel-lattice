# Local-only configuration example.
# Copy to .env if needed. Do not commit .env.

# Python command used by scripts/bootstrap.sh
PYTHON_BIN=python

# Virtual environment directory
VENV_DIR=.venv

# Local resource paths. These are intentionally not committed.
UTAKATA_RAW_DATA_DIR=data/raw
UTAKATA_INTERIM_DATA_DIR=data/interim
UTAKATA_PROCESSED_DATA_DIR=data/processed
UTAKATA_OUTPUT_DIR=outputs
UTAKATA_CARRIER_DIR=assets/carriers

# Main local derived corpus path
UTAKATA_CANDIDATE_CSV=data/processed/vowel_lattice_corpus.csv
UTAKATA_OVERLAP_EDGES_CSV=data/processed/candidate_overlap_edges.csv
